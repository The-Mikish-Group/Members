@page "{userId?}"
@model Members.Areas.Member.Pages.MyBillingModel
@{
    ViewData["Title"] = $"{Model.DisplayName} Billing Statement"; // Use DisplayName here
    Layout = "_Layout"; // Or your specific Member Area layout
}

<div class="container mt-4 mb-2">
    <div class="row">
        <div class="col-md-12">
            @* Use DisplayName in the main page header *@
            <h2 class="mb-4">@ViewData["Title"]</h2>

            @if (!Model.IsViewingSelf && !string.IsNullOrEmpty(Model.ViewedUserId))
            {
                <div class="mb-3">
                    @* Link back to EditUser page if admin is viewing and ViewedUserId is available *@
                    <a asp-area="Identity" asp-page="/EditUser" asp-route-id="@Model.ViewedUserId" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Edit User @(Model.DisplayName.Replace("'s", "").Replace(" Billing Statement", ""))
                        @* Attempt to get just the name back, might need refinement *@
                    </a>
                </div>
            }

            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    @* DisplayName also useful here if you want to be more explicit than "Current Balance" *@
                    <h5 class="mb-0">Current Balance for @Model.DisplayName</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-@(Model.CurrentBalance > 0 ? "danger" : "success")">
                        @Model.CurrentBalance.ToString("C")
                    </h3>
                    @if (Model.CurrentBalance > 0)
                    {
                        <p class="text-muted">This account has an outstanding balance.</p>
                    }
                    else if (Model.CurrentBalance == 0)
                    {
                        <p class="text-muted">This account is settled. Thank you!</p>
                    }
                    else
                    {
                        <p class="text-muted">This account has a credit balance.</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    @* And here for transaction history heading *@
                    <h5 class="mb-0">Transaction History for @Model.DisplayName</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Transactions.Any())
                    {
                        <p class="text-center p-3">No transactions found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Description</th>
                                        <th class="text-end">Charge</th>
                                        <th class="text-end">Payment</th>
                                        <th>Type</th>
                                        <th>Status/Method</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var trans in Model.Transactions)
                                    {
                                        <tr>
                                            <td>@trans.Date.ToString("yyyy-MM-dd")</td>
                                            <td>@Html.DisplayFor(modelItem => trans.Description)</td>
                                            <td class="text-end">@trans.ChargeAmount?.ToString("C")</td>
                                            <td class="text-end">@trans.PaymentAmount?.ToString("C")</td>
                                            <td>@Html.DisplayFor(modelItem => trans.Type)</td>
                                            <td>@Html.DisplayFor(modelItem => trans.StatusOrMethod)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table th, .table td {
            vertical-align: middle;
        }
    </style>
}