@page "{userId?}"
@model Members.Areas.Member.Pages.MyBillingModel
@{
    ViewData["Title"] = $"{Model.DisplayName} Billing History"; // Use DisplayName here
    Layout = "_Layout"; // Or your specific Member Area layout
}

<div class="container mt-4 mb-2">
    <div class="row">
        <div class="col-md-12">
            @* Use DisplayName in the main page header *@
            <h2 class="mb-4 text-gold-darker">@ViewData["Title"]</h2>

            @if (!Model.IsViewingSelf && !string.IsNullOrEmpty(Model.ViewedUserId))
            {
                <div class="mb-3">
                    @* Link back to EditUser page if admin is viewing and ViewedUserId is available *@
                    <a asp-area="Identity" asp-page="/EditUser" asp-route-id="@Model.ViewedUserId" class="shadow btn btn-sm btn-back">
                        <i class="bi bi-arrow-left"></i> Back to Edit User @(Model.DisplayName.Replace("'s", "").Replace(" Billing Statement", ""))
                        @* Attempt to get just the name back, might need refinement *@
                    </a>
                </div>
            }

            <div class="card shadow bg-Card-Menu mb-4">
                <div class="card-header">
                    @* DisplayName also useful here if you want to be more explicit than "Current Balance" *@
                    <h5 class="text-gold-darker mb-0">Current Balance for @Model.DisplayName</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-@(Model.CurrentBalance > 0 ? "danger" : "success")">
                        @Model.CurrentBalance.ToString("C")
                    </h3>
                    @if (Model.CurrentBalance > 0)
                    {
                        <p class="text-muted">This account has an outstanding balance.</p>
                    }
                    else if (Model.CurrentBalance == 0)
                    {
                        <p class="text-muted">This account is settled. Thank you!</p>
                    }
                    else
                    {
                        <p class="text-muted">This account has a credit balance.</p>
                    }
                </div>
            </div>

            <div class="card shadow bg-Card-Menu mb-2">
                <div class="card-header">
                    @* And here for transaction history heading *@
                    <h5 class="text-gold-darker mb-0">Transaction History for @Model.DisplayName</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Transactions.Any())
                    {
                        <p class="text-center p-3">No transactions found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="w-100 shadow">
                                <thead class="table-light">
                                    <tr class="bg-gold-dark text-white py-1">
                                        <th class="text-white ps-1 py-1">Date</th>
                                        <th class="text-white py-1">Description</th>
                                        <th class="text-white py-1 text-end">Charge</th>
                                        <th class="text-white py-1 text-end">Payment</th>
                                        <th class="text-white py-1">Type</th>
                                        <th class="text-white py-1">Status/Method</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int i = 0; // Declare and initialize the variable 'i' before the loop
                                    }
                                    @foreach (var trans in Model.Transactions)
                                    {
                                        <tr class="text-gold-darker @(i % 2 == 0 ? "row-even" : "row-odd")">
                                            <td class="ps-1 py-1 text-gold-darker">@trans.Date.ToString("yyyy-MM-dd")</td>
                                            <td class="py-1 text-gold-darker">@Html.DisplayFor(modelItem => trans.Description)</td>
                                            <td class="py-1 text-gold-darker text-end">@trans.ChargeAmount?.ToString("C")</td>
                                            <td class="py-1 text-gold-darker text-end">@trans.PaymentAmount?.ToString("C")</td>
                                            <td class="py-1 text-gold-darker">@Html.DisplayFor(modelItem => trans.Type)</td>
                                            <td class="py-1 text-gold-darker">@Html.DisplayFor(modelItem => trans.StatusOrMethod)</td>
                                        </tr>

                                        i++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table th, .table td {
            vertical-align: middle;
        }

        .row-even {
            background-color: antiquewhite
        }

        .row-odd {
            background-color: #ffffff;
        }

        .even-row > td,
        .odd-row > td {
            background-color: inherit !important;
        }

        .table th a {
            text-decoration: none;
            color: inherit;
        }

            .table th a:hover {
                text-decoration: underline;
            }

        .table th .bi { /* For sort indicators */
            font-size: 0.9em;
            margin-left: 0.25rem;
        }
    </style>
}

@section Scripts {    
    <script>

    </script>
}