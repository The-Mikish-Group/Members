@page
@model Members.Areas.Member.Pages.MyBillingModel
@{
    ViewData["Title"] = "My Billing Statement";
    // Assuming a layout for the Member area or use the main one
    // e.g., Layout = "/Pages/Shared/_Layout.cshtml";
    // Or if you have a specific one: Layout = "/Areas/Member/Pages/Shared/_Layout.cshtml";
    // For now, let's assume it will pick up a default or you'll adjust.
    // You might need to create a _ViewStart.cshtml in /Areas/Member/Pages/
    // if you want to specify a default layout for all pages in this area.
    Layout = "_Layout"; // This will look for /Pages/Shared/_Layout.cshtml or /Views/Shared/_Layout.cshtml
                        // or /Areas/Member/Pages/Shared/_Layout.cshtml if it exists.
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2 class="mb-4">@ViewData["Title"]</h2>

            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Current Balance</h5>
                </div>
                <div class="card-body">
                    <h3 class="text-@(Model.CurrentBalance > 0 ? "danger" : "success")">
                        @Model.CurrentBalance.ToString("C")
                    </h3>
                    @if (Model.CurrentBalance > 0)
                    {
                        <p class="text-muted">You have an outstanding balance.</p>
                    }
                    else if (Model.CurrentBalance == 0)
                    {
                        <p class="text-muted">Your account is settled. Thank you!</p>
                    }
                    else
                    {
                        <p class="text-muted">You have a credit balance.</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0">Transaction History</h5>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Transactions.Any())
                    {
                        <p class="text-center p-3">No transactions found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Description</th>
                                        <th class="text-end">Charge</th>
                                        <th class="text-end">Payment</th>
                                        <th>Type</th>
                                        <th>Status/Method</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var trans in Model.Transactions)
                                    {
                                        <tr>
                                            <td>@trans.Date.ToString("yyyy-MM-dd")</td>
                                            <td>@Html.DisplayFor(modelItem => trans.Description)</td>
                                            <td class="text-end">@trans.ChargeAmount?.ToString("C")</td>
                                            <td class="text-end">@trans.PaymentAmount?.ToString("C")</td>
                                            <td>@Html.DisplayFor(modelItem => trans.Type)</td>
                                            <td>@Html.DisplayFor(modelItem => trans.StatusOrMethod)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .table th, .table td {
            vertical-align: middle;
        }
    </style>
}