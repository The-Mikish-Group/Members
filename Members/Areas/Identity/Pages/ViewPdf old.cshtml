@page
@model Members.Areas.Identity.Pages.ViewPdfModel
@{
    ViewData["Title"] = "View PDF";
       
    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://www.oaks-village.com/Identity/Account/ViewPdf";
    ViewData["OGTitle"] = "View Pdf";
    ViewData["OGDescription"] = "Oaks-Village View Pdf";
    ViewData["OGURL"] = "https://www.oaks-village.com/Identity/Account/ViewPdf";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional
      
}

<head>
    <title>@ViewData["Title"]</title>
</head>

@if (Model.IsAuthorized)
{
    
    <div class="mt-3 mt-lg-2 pt-0 @* bg-white *@" style="position: relative; margin: 0 auto; max-width: 800px;">
        <a id="closeButton" href="javascript:history.back()" class="close-button text-decoration-none text-black ps-2 fs-3 hidden">
            <i class="bi bi-x"></i>
        </a>
    </div>

    <div id="pdf-viewer-container" style="display:block; margin: 0 auto; max-width: 800px;"></div>
    

    @section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Get the filename from the model
            var fileName = '@Model.FileName';

            // Construct the URL to fetch the PDF
            var url = '/File/ViewPdf?fileName=' + fileName;

            // Get the container element
            var pdfContainer = document.getElementById('pdf-viewer-container');

            // Get the close button
            var closeButton = document.getElementById('closeButton');

            // Load the PDF document using PDF.js
            pdfjsLib.getDocument(url).promise.then(function(pdfDoc) {

                // Function to render a single page
                var renderPage = function(pageNum) {
                    pdfDoc.getPage(pageNum).then(function(page) {

                        // Get the original viewport dimensions
                        var originalViewport = page.getViewport({ scale: 1 });

                        // Set the rendering scale for higher resolution (less blurry)
                        var renderScale = 4;

                        // Get the viewport dimensions at the higher resolution
                        var renderViewport = page.getViewport({ scale: renderScale });

                        // Create a canvas element for rendering
                        var canvas = document.createElement('canvas');

                        // Get the 2D rendering context
                        var context = canvas.getContext('2d');

                        // Set canvas dimensions
                        canvas.height = renderViewport.height;
                        canvas.width = renderViewport.width;

                        // Define the rendering context
                        var renderContext = {
                            canvasContext: context,
                            viewport: renderViewport,
                        };

                        // Render the page
                        page.render(renderContext).promise.then(function() {

                            // Calculate scale based on container width for responsiveness
                            var containerWidth = pdfContainer.offsetWidth;
                            var displayScale = containerWidth / originalViewport.width;

                            // Scale the canvas down to the display size
                            canvas.style.width = (originalViewport.width * displayScale) + "px";
                            canvas.style.height = (originalViewport.height * displayScale) + "px";

                            // Style the canvas
                            canvas.style.display = 'block';
                            canvas.style.marginBottom = '10px';

                            // Append the canvas to the container
                            pdfContainer.appendChild(canvas);

                            // Render the next page if there are more pages
                            if (pageNum < pdfDoc.numPages) {
                                renderPage(pageNum + 1);
                            } else {
                                // PDF rendering is complete, show the close button
                                closeButton.classList.remove('hidden');
                            }
                        });
                    });
                };

                // Start rendering from the first page
                renderPage(1);
            });
        });
    </script>
    }
}
else
{

var returnUrl = HttpContext.Request.Path + HttpContext.Request.QueryString;

// User is not authorized to view the PDF
<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body text-center">
                <p class="card-text">This is the <strong>Members</strong> area of Oaks-Village.com.</p>
                <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@returnUrl">Login</a>
            </div>
        </div>
    </div>
</div>
}

<style>
    .close-button {
        position: absolute;
        top: 1px;
        left: 2px; /* Changed from right: 10px; */
        font-size: 24px;
        color: #333;
        text-decoration: none;
        cursor: pointer;
        z-index: 10;
    }

        .close-button:hover {
            color: #000;
        }

    .hidden {
        display: none;
    }
</style>