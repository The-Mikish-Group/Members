@page
@model ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Resend email confirmation";

    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://www.oaks-village.com/Identity/Account/ResendEmailConfirmation";
    ViewData["OGTitle"] = "Resend email confirmation";
    ViewData["OGDescription"] = "Oaks-Village Resend email confirmation";
    ViewData["OGURL"] = "https://www.oaks-village.com/Identity/Account/ResendEmailConfirmation";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional

}

<head>
    <title>@ViewData["Title"]</title>
</head>

<!-- Logo Image -->
<div class="container row m-0 ps-0 pb-2 pb-lg-4 gx-0 gy-2 gy-lg-3 mx-auto text-center">
    <div class="col-12 mt-0 ps-0">
        <partial name="_OaksTreesLogo" />
    </div>
</div>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow rounded m-0 p-0 bg-gold-light">
                <div class="card-body p-2">
                    <h1 class="text-center mb-4 text-gold-darker">
                        <i class="bi bi-envelope-check-fill"></i> @ViewData["Title"]
                    </h1>
                    <h4 class="text-center mb-2 text-gold-darker">Enter your email.</h4>
                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger text-center xmb-3" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email" class="form-label">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-sm btn-primary">
                                <i class="bi bi-arrow-clockwise"></i> Resend
                            </button>
                            <a href="~/" class="btn btn-sm btn-secondary">
                                <i class="bi bi-house-fill"></i> Home
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
