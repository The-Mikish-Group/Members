@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Email Confirmed";

    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://www.oaks-village.com/Identity/Account/ConfirmEmail";
    ViewData["OGTitle"] = "Confirm email";
    ViewData["OGDescription"] = "Oaks-Village Confirm email";
    ViewData["OGURL"] = "https://www.oaks-village.com/Identity/Account/ConfirmEmail";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional

}

<head>
    <title>@ViewData["Title"]</title>
</head>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow rounded p-0 bg-Card-Menu" style="max-width: 400px; width: 90%;">
        <div class="card-body">
            <h1 class="mb-4">
                <i class="bi bi-envelope-check-fill"></i> @ViewData["Title"]
            </h1>
            <!-- <partial name="_StatusMessage" model="Model.StatusMessage" /> -->
            <div class="text-center mt-3">
                <a href="/" class="btn btn-sm btn-success"><i class="bi bi-house-fill"></i> Home</a>
            </div>
        </div>
    </div>
</div>