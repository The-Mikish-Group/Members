@page
@model LogoutModel
@{
    ViewData["Title"] = "Logout";

    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://www.oaks-village.com/Identity/Account/Logout";
    ViewData["OGTitle"] = "Logout";
    ViewData["OGDescription"] = "Oaks-Village Logout";
    ViewData["OGURL"] = "https://www.oaks-village.com/Identity/Account/Logout";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional

}

<head>
    <title>@ViewData["Title"]</title>
</head>

<header>
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" action="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Info")" method="post">
                <button type="submit" class="nav-link btn btn-sm btn-link text-gold-darker">Click here to Logout</button>
            </form>
        }
        else
        {
            <p class="text-gold-darker">You have successfully logged out of the application.</p>
        }
    }
</header>
