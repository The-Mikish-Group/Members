                    <h1 class="text-danger mb-4">@ViewData["Title"]</h1>
                    <p class="text-danger mb-4">You do not have access to this resource.</p>

                    <a href="/" class="btn btn-sm btn-secondary"><i class="bi bi-house-fill"></i> Home</a>
