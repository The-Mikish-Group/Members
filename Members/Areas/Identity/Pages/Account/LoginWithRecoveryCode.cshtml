@page
@model LoginWithRecoveryCodeModel
@{
    ViewData["Title"] = "Recovery code verification";

    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://www.oaks-village.com/Identity/Manage/LoginWithRecoveryCode";
    ViewData["OGTitle"] = "Register";
    ViewData["OGDescription"] = "Oaks-Village Register";
    ViewData["OGURL"] = "https://www.oaks-village.com/Identity/Manage/LoginWithRecoveryCode";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional

}

<head>
    <title>@ViewData["Title"]</title>
</head>

<div class="container my-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow rounded m-4 p-4 bg-Card-Menu">
                <div class="card-body">
                    <h1 class="text-center mb-4 text-gold-darker">
                        <i class="bi bi-key"></i> <i class="bi bi-arrow-clockwise"></i> @ViewData["Title"]
                    </h1>
                    <p class="text-center text-gold-darker">
                        You have requested to log in with a recovery code. This login will not be remembered until you provide
                        an authenticator app code at log in or disable 2FA and log in again.
                    </p>
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3" role="alert"></div>
                        <div class="form-floating mb-3">
                            <input asp-for="Input.RecoveryCode" class="form-control" autocomplete="off" placeholder="RecoveryCode" />
                            <label asp-for="Input.RecoveryCode" class="form-label">Recovery Code</label>
                            <span asp-validation-for="Input.RecoveryCode" class="text-danger"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-sm btn-primary">Log in</button>
                            <a href="~/" class="btn btn-sm btn-danger">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}