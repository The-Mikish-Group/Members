@page
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

@model Members.Areas.Identity.Pages.UsersModel
@{
    ViewData["Title"] = "Edit Members";

    string siteName = Environment.GetEnvironmentVariable("SITE_NAME")!;
}

<head>

    <title>@ViewData["Title"]</title>

    <style>
        .table-striped tbody tr.user-row:nth-of-type(odd):hover,
        .table-striped tbody tr.user-row:nth-of-type(even):hover,
        tbody tr.user-row:hover {
            cursor: pointer;
            border: 2px solid green;
        }
        /* Hide columns when ShowExtraFields is false */
        .hide-extra-fields th.extra-field,
        .hide-extra-fields td.extra-field {
            display: none;
        }

         /* Add some padding to the right of the table if it's scrollable */
         /* This helps ensure the last column's sort arrow is visible when scrolled all the way right */
         .table-responsive {
             padding-bottom: .5em; /* Add padding to the bottom for horizontal scrollbar appearance */
         }
    </style>
</head>

@if (SignInManager.IsSignedIn(User) && (User.IsInRole("Admin") || User.IsInRole("Manager")))
{
    <div class="container my-4">

        <div class="row align-items-center mb-3">
            <div class="col-auto d-flex align-items-center">
                <h1 class="text-gold-darker"><i class="bi bi-people-fill"></i> Members</h1>
            </div>
        </div>

        <div class="mb-3">

            <h6 class="text-gold-darker mb-1 ps-2">(Also: "Bad", "No Role" and "Not Confirmed")</h6>

            <form method="get" id="searchForm">

                <div class="input-group">

                    <button class="btn btn-sm btn-info" type="submit" id="searchButton"><i class="bi bi-search"></i></button>

                    <input type="text" class="form-control text-gold-darker" placeholder="Search..." asp-for="SearchTerm" id="searchInput" />

                    <input type="hidden" asp-for="PageNumber" />
                    <input type="hidden" asp-for="PageSize" />
                    <input type="hidden" asp-for="SortColumn" />
                    <input type="hidden" asp-for="SortOrder" />
                    <input type="hidden" asp-for="ShowExtraFields" id="showExtraFieldsHidden" />

                    <button class="btn btn-sm btn-outline-secondary bg-success-subtle" type="button" id="clearSearch" style="display: none;">
                        <i class="bi bi-x text-black"></i>
                    </button>

                </div>
            </form>
        </div>

        <div class="mb-2 d-flex align-items-center">
            <span id="userCount" class="me-3">Total Members: @Model.TotalUsers</span>

            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="showExtraFieldsCheckbox"
                       @(Model.ShowExtraFields ? "checked" : "")>
                <label class="form-check-label" for="showExtraFieldsCheckbox">
                    Show Full Details
                </label>
            </div>

        </div>

        <div class="table-responsive mb-3" id="usersTableContainer">

            <table class="table table-striped table-bordered @(Model.ShowExtraFields ? "" : "hide-extra-fields")" data-search-term="@Model.SearchTerm" id="userTable">
                <thead>
                    <tr>
                        <th>

                            <a class="nav-link"
                               asp-page="./Users"
                               asp-route-sortcolumn="fullname"
                               asp-route-sortorder="@(Model.SortOrder == "asc" && Model.SortColumn == "fullname" ? "desc" : "asc")"
                               asp-route-searchterm="@Model.SearchTerm"
                               asp-route-pageNumber="@Model.PageNumber"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-showextrafields="@Model.ShowExtraFields">
                                Full Name
                                @if (Model.SortColumn == "fullname")
                                {
                                    @(Model.SortOrder == "asc" ? Html.Raw("&#9650;") : Html.Raw("&#9660;"))
                                }
                            </a>
                        </th>
                        <th>

                            <a class="nav-link"
                               asp-page="./Users"
                               asp-route-sortcolumn="email"
                               asp-route-sortorder="@(Model.SortOrder == "asc" && Model.SortColumn == "email" ? "desc" : "asc")"
                               asp-route-searchterm="@Model.SearchTerm"
                               asp-route-pageNumber="@Model.PageNumber"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-showextrafields="@Model.ShowExtraFields">
                                Email
                                @if (Model.SortColumn == "email")
                                {
                                    @(Model.SortOrder == "asc" ? Html.Raw("&#9650;") : Html.Raw("&#9660;"))
                                }
                            </a>
                        </th>
                        <th>

                            <a class="nav-link"
                               asp-page="./Users"
                               asp-route-sortcolumn="emailconfirmed"
                               asp-route-sortorder="@(Model.SortOrder == "asc" && Model.SortColumn == "emailconfirmed" ? "desc" : "asc")"
                               asp-route-searchterm="@Model.SearchTerm"
                               asp-route-pageNumber="@Model.PageNumber"
                               asp-route-pageSize="@Model.PageSize"
                               asp-route-showextrafields="@Model.ShowExtraFields">
                                Email <i class="bi bi-check-lg text-success"></i>
                                @if (Model.SortColumn == "emailconfirmed")
                                {
                                    @(Model.SortOrder == "asc" ? Html.Raw("&#9650;") : Html.Raw("&#9660;"))
                                }
                            </a>
                        </th>
                        <th>

                            <a class="nav-link"
                               asp-page="./Users"
                               asp-route-sortcolumn="phonenumber"
                               asp-route-sortorder="@(Model.SortOrder == "asc" && Model.SortColumn == "phonenumber" ? "desc" : "asc")"
                               asp-route-searchterm="@Model.SearchTerm"
                               asp-route-pageNumber="@Model.PageNumber"
                               asp-route-pageSize="@Model.PageSize"
