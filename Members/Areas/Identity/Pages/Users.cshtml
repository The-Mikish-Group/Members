                        }
                        </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                       <tr class="user-row text-gold-darker" data-user-id="@user.Id" data-show-extra-fields="@Model.ShowExtraFields">

                           <td>@user.FullName</td>

                           <td>@user.Email</td>
                           <td>
                                @if (user.EmailConfirmed)
                                {
                                    <i class="bi bi-check-lg text-success"></i>
                                }
                           </td>

                           <td>@user.PhoneNumber</td>
                           <td>
                                @if (user.PhoneNumberConfirmed)
                                {
                                    <i class="bi bi-check-lg text-success"></i>
                                }
                           </td>
                           <td>
                                @if (user.Roles != null)
                                {
                                    @foreach (var role in user.Roles)
                                    {
                                        <span>@role</span>
                                        <br />
                                    }
                                }
                           </td>

                           <td data-utc-time="@user.LastLogin?.ToString("yyyy-MM-ddTHH:mm:ssZ")" class="local-login-time">
                                @user.LastLogin?.ToString("yyyy-MM-dd HH:mm:ss UTC")
                           </td>

                            @if (Model.ShowExtraFields)
                            {
                                <td class="extra-field">@user.FirstName</td>
                                <td class="extra-field">@user.MiddleName</td>
                                <td class="extra-field">@user.LastName</td>
                                <td class="extra-field">@user.HomePhoneNumber</td>
                                <td class="extra-field">@user.AddressLine1</td>
                                <td class="extra-field">@user.AddressLine2</td>
                                <td class="extra-field">@user.City</td>
                                <td class="extra-field">@user.State</td>
                                <td class="extra-field">@user.ZipCode</td>
                                <td class="extra-field">@user.Plot</td>
                                <td class="extra-field">@(user.Birthday.HasValue? user.Birthday.Value.ToShortDateString() : "")</td>
                                <td class="extra-field">@(user.Anniversary.HasValue? user.Anniversary.Value.ToShortDateString() : "")</td>
                            }
                            </tr>
                    }
                </tbody>
            </table>
        </div>

        @{
            var totalPages = Model.TotalPages;
            var currentPage = Model.PageNumber;
            var pageDisplayLimit = 5; // Set the desired number of pages to display

            // Calculate the start and end pages to display
            var startPage = Math.Max(1, currentPage - (int)Math.Floor((double)pageDisplayLimit / 2));
            var endPage = Math.Min(totalPages, startPage + pageDisplayLimit - 1);

            // Adjust startPage if endPage was capped by totalPages
            if (endPage - startPage + 1 < pageDisplayLimit)
            {
                startPage = Math.Max(1, endPage - pageDisplayLimit + 1);
            }
        }

        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="./Users"
                       asp-route-PageNumber="@(currentPage - 1)"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-SortColumn="@Model.SortColumn"
                       asp-route-SortOrder="@Model.SortOrder"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-showextrafields="@Model.ShowExtraFields">
                        &laquo;
                    </a>
                </li>

                @for (var i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-page="./Users"
                           asp-route-PageNumber="@i"
                           asp-route-PageSize="@Model.PageSize"
                           asp-route-SortColumn="@Model.SortColumn"
                           asp-route-SortOrder="@Model.SortOrder"
                           asp-route-SearchTerm="@Model.SearchTerm"
                           asp-route-showextrafields="@Model.ShowExtraFields">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="./Users"
                       asp-route-PageNumber="@(currentPage + 1)"
                       asp-route-PageSize="@Model.PageSize"
                       asp-route-SortColumn="@Model.SortColumn"
                       asp-route-SortOrder="@Model.SortOrder"
                       asp-route-SearchTerm="@Model.SearchTerm"
                       asp-route-showextrafields="@Model.ShowExtraFields">
                        &raquo;
                    </a>
                </li>

            </ul>

        </nav>

    </div>
}
else
{
    <div class="text-center mt-4">
        <p class="mb-1 text-gold-darker">This is an Admin area of @siteName.</p>
        <p class="mb-2 text-gold-darker">Please Login with Administration credentials.</p>
        <a class="nav-link text-gold fs-3" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const tableContainer = document.getElementById('usersTableContainer'); // Get the table container
            const searchInput = document.getElementById('searchInput');
            const clearSearch = document.getElementById('clearSearch');
            const searchButton = document.getElementById('searchButton');
            const searchForm = document.getElementById('searchForm');
            const userTable = document.getElementById('userTable'); // Use the ID
            const showExtraFieldsCheckbox = document.getElementById('showExtraFieldsCheckbox');
            const showExtraFieldsHidden = document.getElementById('showExtraFieldsHidden');

            // Function to save scroll position
            function saveScrollPosition() {
                if (tableContainer) {
                    sessionStorage.setItem('usersTableScrollLeft', tableContainer.scrollLeft);
                }
            }

            // Function to restore scroll position
            function restoreScrollPosition() {
                if (tableContainer) {
                    const savedScrollLeft = sessionStorage.getItem('usersTableScrollLeft');
                    if (savedScrollLeft !== null) {
                        tableContainer.scrollLeft = parseInt(savedScrollLeft, 10);
                        // Optionally clear the stored value after restoring
                        // sessionStorage.removeItem('usersTableScrollLeft'); // Removing this line keeps the scroll position on subsequent partial reloads like clicking a row for edit.
                    }
                }
            }

            // --- Save scroll position before navigation/form submission ---

            // Save scroll position before submitting the search form (either by button or Enter key)
            if (searchForm) {
                 searchForm.addEventListener('submit', saveScrollPosition);
            }

            // Save scroll position before navigating via sorting links
            const sortLinks = document.querySelectorAll('#userTable thead a.nav-link');
            sortLinks.forEach(link => {
                link.addEventListener('click', saveScrollPosition);
            });

            // Save scroll position before navigating via pagination links
            const paginationLinks = document.querySelectorAll('.pagination a.page-link');
            paginationLinks.forEach(link => {
                link.addEventListener('click', saveScrollPosition);
            });

            // Save scroll position before navigating via row click to EditUser
            const tableRows = userTable ? userTable.querySelectorAll('tbody tr.user-row') : [];
            tableRows.forEach(row => {
                row.addEventListener('click', saveScrollPosition);
            });


            // --- Restore scroll position when the page loads ---
            restoreScrollPosition();


            // --- Existing JavaScript (integrated) ---

            // Handle Search Input Clear Button visibility
            searchInput.addEventListener('input', function() {
                clearSearch.style.display = this.value ? 'block' : 'none';
            });

            // Handle Clear Search Button click
            clearSearch.addEventListener('click', function() {
                searchInput.value = '';
                clearSearch.style.display = 'none';
                // When clearing search, submit the form to reset pagination, sorting, and preserve toggle state
                searchForm.submit();
            });

            // Added event listener for Enter key on search input
            searchInput.addEventListener('keydown', function(event) {
                if (event.key === 'Enter') {
                    event.preventDefault(); // Prevent default form submission
                    // The submit event listener on the form will handle saving scroll position and submitting
                    searchForm.submit(); // Trigger form submission
                }
            });

            // Initial check on page load for clear button visibility
            clearSearch.style.display = searchInput.value ? 'block' : 'none';


            // Handle Show Extra Fields Toggle
            if (showExtraFieldsCheckbox && showExtraFieldsHidden && searchForm) {
                showExtraFieldsCheckbox.addEventListener('change', function() {
                    // Update the value of the hidden input field to match the checkbox state
                    showExtraFieldsHidden.value = this.checked;
                    // Submit the form to refresh the page with the new toggle state
                    // The submit event listener on the form will handle saving scroll position and submitting
                    searchForm.submit();
                });
            }


            // Handle Row Click to Edit User (Modified to just navigate, scroll position is saved by click listener)
            if (userTable) {
                const userTableRows = userTable.querySelectorAll('tbody tr.user-row'); // Re-select if needed, or use the existing tableRows variable
                 userTableRows.forEach(row => {
                    row.addEventListener('click', function (event) {
                        // Prevent the default link behavior if the click was on a link inside the row
                        if (event.target.tagName === 'A') {
                             return;
                        }

                        const userId = this.dataset.userId;

                        // Retrieve current state from hidden inputs (more reliable than dataset)
                        const pageNumber = document.querySelector('input[name="PageNumber"]').value;
                        const pageSize = document.querySelector('input[name="PageSize"]').value;
                        const sortColumn = document.querySelector('input[name="SortColumn"]').value;
                        const sortOrder = document.querySelector('input[name="SortOrder"]').value;
                        const searchTerm = document.getElementById('searchInput').value; // Get actual input value
                        const showExtraFields = document.getElementById('showExtraFieldsHidden').value; // Get actual hidden input value ('true' or 'false')


                        let returnUrl = `${window.location.pathname}?PageNumber=${pageNumber}&PageSize=${pageSize}`;

                        if (sortColumn) {
                            returnUrl += `&SortColumn=${sortColumn}&SortOrder=${sortOrder}`;
                        }
                        if (searchTerm && searchTerm.trim() !== '') {
                            returnUrl += `&SearchTerm=${encodeURIComponent(searchTerm.trim())}`;
                        }

                        // Append ShowExtraFields state (should already be 'true' or 'false')
                        returnUrl += `&ShowExtraFields=${showExtraFields}`; // Use the value directly

                        // The click event listener on the row already calls saveScrollPosition()
                        // Now, navigate to the edit page
                        window.location.href = `/Identity/EditUser?id=${userId}&returnUrl=${encodeURIComponent(returnUrl)}`;
                    });
                 });
            }


            // Localize Last Login Time
            const lastLoginElements = document.querySelectorAll('.local-login-time');
            lastLoginElements.forEach(function (element) {
                const utcTimeString = element.getAttribute('data-utc-time');
                if (utcTimeString) {
                    const date = new Date(utcTimeString);
                    // Format the date and time in the local timezone
                    const options = { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: true };
                    try {
                         const localTimeString = date.toLocaleString(undefined, options);
                         element.textContent = localTimeString;
                    } catch (e) {
                         console.error("Error formatting date:", e);
                         // Fallback to original text if formatting fails
                         element.textContent = utcTimeString + " (UTC)";
                    }
                } else {
                    element.textContent = 'Never';
                }
            });
            // --- End Existing JavaScript ---
        });
    </script>
}