                    }, delay);
                };
            }
            // --- End Debounce Function ---

            // --- Function to prepare and submit the form ---
            // This function ensures all hidden inputs are updated before submitting.
            function prepareAndSubmitForm() {
                console.log("prepareAndSubmitForm called.");

                // Update hidden inputs from their corresponding UI elements if they exist
                if (searchTermInput && searchInput) {
                    searchTermInput.value = searchInput.value;
                }
                if (showExtraFieldsHidden && showExtraFieldsCheckbox) {
                    showExtraFieldsHidden.value = showExtraFieldsCheckbox.checked ? "True" : "False";
                }
                // Note: PageNumber, PageSize, SortColumn, SortOrder are updated by their
                // specific event handlers (pagination/sort link clicks) before this is called,
                // or they are set by the server on initial load.

                 // Add a flag to the form data to indicate we want to refocus the search input after reload
                 // This requires adding a hidden input named 'RefocusSearch' to your form in Users.cshtml
                 const refocusInput = searchForm.querySelector('input[name="RefocusSearch"]');
                 if (refocusInput) {
                     // Only set refocus to true if the submission was likely triggered by search input
                     // (This is a heuristic, could be refined)
                     if (document.activeElement === searchInput || document.activeElement === clearSearch || document.activeElement === searchButton) {
                          refocusInput.value = 'true';
                     } else {
                          refocusInput.value = 'false';
                     }
                 } else {
                     console.warn("Hidden input 'RefocusSearch' not found in the form.");
                 }


                console.log("Submitting form with state:");
                console.log("  PageNumber:", pageNumberInput ? pageNumberInput.value : 'Not found');
                console.log("  PageSize:", pageSizeInput ? pageSizeInput.value : 'Not found');
                console.log("  SortColumn:", sortColumnInput ? sortColumnInput.value : 'Not found');
                console.log("  SortOrder:", sortOrderInput ? sortOrderInput.value : 'Not found');
                console.log("  SearchTerm:", searchTermInput ? searchTermInput.value : 'Not found');
                console.log("  ShowExtraFields:", showExtraFieldsHidden ? showExtraFieldsHidden.value : 'Not found');
                console.log("  RefocusSearch:", refocusInput ? refocusInput.value : 'N/A');


                saveScrollPosition(); // Save scroll before submitting
                searchForm.submit(); // Submit the form
            }
            // --- End Function to prepare and submit the form ---

            // --- Handle Live Search Input ---
            if (searchInput && searchForm) {
                 // Use debounce to prevent submitting on every single keypress
                 const debouncedSubmit = debounce(function() {
                     // Reset to the first page on search input change
                     document.querySelector('input[name="PageNumber"]').value = 1;
                     saveScrollPosition(); // Save scroll before submitting
                     searchForm.submit(); // Submit the form
                 }, 10); // Adjust delay (milliseconds) as needed

                 searchInput.addEventListener('input', function() {
                     clearSearch.style.display = this.value ? 'block' : 'none';
                     debouncedSubmit(); // Call the debounced submit function
                 });

                 // Prevent the search input from losing focus after form submission
                 // This is a bit tricky with full form submits. We'll try to re-focus
                 // after the page reloads. This requires the browser to remember focus,
                 // or we need to pass a flag in the URL. A simpler approach for now
                 // is just to submit and let the browser handle focus, but the user
                 // explicitly asked to stay in the field. Let's add a flag.

                 // Add a hidden input to indicate if we should re-focus the search input
                 let refocusInput = document.createElement('input');
                 refocusInput.type = 'hidden';
                 refocusInput.name = 'RefocusSearch';
                 refocusInput.value = 'false'; // Default
                 searchForm.appendChild(refocusInput);


                 // When the input event triggers a submit, set the refocus flag
                 searchInput.addEventListener('input', function() {
                     clearSearch.style.display = this.value ? 'block' : 'none';
                     refocusInput.value = 'true'; // Set flag before submitting
                     debouncedSubmit();
                 });

                 // When the clear search button triggers a submit, set the refocus flag
                 clearSearch.addEventListener('click', function() {
                     searchInput.value = '';
                     clearSearch.style.display = 'none';
                     // Reset to the first page when clearing search
                     document.querySelector('input[name="PageNumber"]').value = 1;
                     refocusInput.value = 'true'; // Set flag before submitting
                     saveScrollPosition(); // Save scroll before submitting
                     searchForm.submit();
                 });


                 // When the search button is clicked or Enter is pressed, also set the refocus flag
                 // The keydown listener for Enter on searchInput already triggers searchButton.click()
                 if (searchButton) {
                     searchButton.addEventListener('click', function(event) {
                         // Prevent default form submission if button is clicked (form submit is handled by input/clear)
                         // event.preventDefault(); // Keep default submit for button click/Enter for now
                         refocusInput.value = 'true'; // Set flag before submitting
                         saveScrollPosition(); // Save scroll before submitting
                         // The form will submit normally here
                     });
                 }


                 // On page load, check if the refocus flag was set and re-focus the input
                 const urlParams = new URLSearchParams(window.location.search);
                 if (urlParams.get('RefocusSearch') === 'true') {
                     // Remove the flag from the URL to prevent infinite loops on refresh
                     urlParams.delete('RefocusSearch');
                     const newUrl = `${window.location.pathname}?${urlParams.toString()}${urlParams.toString() ? '&' : ''}${window.location.hash}`;
                     // Use replaceState to change the URL without adding to history
                     window.history.replaceState({}, document.title, newUrl);

                     // Re-focus the input after a small delay to ensure the DOM is ready
                     setTimeout(() => {
                         searchInput.focus();
                         // Move cursor to the end of the input
                         const len = searchInput.value.length;
                         searchInput.setSelectionRange(len, len);
                     }, 10); // Small delay
                 }

                 // Initial check on page load for clear button visibility
                 clearSearch.style.display = searchInput.value ? 'block' : 'none';
            }

            // --- End Handle Live Search Input ---
            if (showExtraFieldsHidden && showExtraFieldsCheckbox) {
                    showExtraFieldsHidden.value = showExtraFieldsCheckbox.checked ? "True" : "False";
            }

            // --- Handle Show Extra Fields Toggle ---
            if (showExtraFieldsCheckbox && showExtraFieldsHidden) {
                showExtraFieldsCheckbox.addEventListener('change', function() {
                    console.log("Show Extra Fields toggle changed. New checkbox state:", this.checked);
                    // Update the hidden input value immediately to "True" or "False" string
                    showExtraFieldsHidden.value = this.checked ? "True" : "False";
                    console.log("showExtraFieldsHidden value set to:", showExtraFieldsHidden.value);
                    // Reset to the first page on toggle change
                    if (pageNumberInput) pageNumberInput.value = 1;
                    prepareAndSubmitForm(); // Trigger form submit
                });
            }
            // --- End Handle Show Extra Fields Toggle ---

            // Handle Row Click to Edit User (Original logic, ensures returnUrl includes search term)
            if (userTable) {
                const userTableRows = userTable.querySelectorAll('tbody tr.user-row');
                 userTableRows.forEach(row => {
                    row.addEventListener('click', function (event) {
                        // Prevent the default link behavior if the click was on a link inside the row
                        if (event.target.tagName === 'A') {
                             return;
                        }

                        const userId = this.dataset.userId;

                        // Retrieve current state from hidden inputs and search input
                        const pageNumber = document.querySelector('input[name="PageNumber"]').value;
                        const pageSize = document.querySelector('input[name="PageSize"]').value;
                        const sortColumn = document.querySelector('input[name="SortColumn"]').value;
                        const sortOrder = document.querySelector('input[name="SortOrder"]').value;
                        const searchTerm = document.getElementById('searchInput').value;
                        const showExtraFields = document.getElementById('showExtraFieldsHidden').value;

                        let returnUrl = `${window.location.pathname}?PageNumber=${pageNumber}&PageSize=${pageSize}`;

                        if (sortColumn) {
                            returnUrl += `&SortColumn=${sortColumn}&SortOrder=${sortOrder}`;
                        }
                        // Ensure searchTerm is included if it has a value
                        if (searchTerm && searchTerm.trim() !== '') {
                            returnUrl += `&SearchTerm=${encodeURIComponent(searchTerm.trim())}`;
                        }

                        returnUrl += `&ShowExtraFields=${showExtraFields}`;

                        saveScrollPosition(); // Save before navigating
                        window.location.href = `/Identity/EditUser?id=${userId}&returnUrl=${encodeURIComponent(returnUrl)}`;
                    });
                 });
            }

            // Localize Last Login Time
            const lastLoginElements = document.querySelectorAll('.local-login-time');
            lastLoginElements.forEach(function (element) {
                const utcTimeString = element.getAttribute('data-utc-time');
                if (utcTimeString) {
                    const date = new Date(utcTimeString);
                    const options = { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', hour12: true };
                    try {
                         const localTimeString = date.toLocaleString(undefined, options);
                         element.textContent = localTimeString;
                    } catch (e) {
                         console.error("Error formatting date:", e);
                         element.textContent = utcTimeString + " (UTC)";
                    }
                } else {
                    element.textContent = 'Never';
                }
            });

             // Restore scroll position on initial page load
            restoreScrollPosition();
        });
    </script>
