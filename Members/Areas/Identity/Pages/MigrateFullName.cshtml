@page
@model Members.Areas.Identity.Pages.MigrateFullNameModel

@{
    ViewData["Title"] = "Migrate Full Name Data";
}

<h1>@ViewData["Title"]</h1>

<p>This page will parse the existing FullName claims and populate the FirstName, MiddleName, and LastName fields in the UserProfile table.</p>

@if (!string.IsNullOrEmpty(Model.MigrationResult))
{
    <div class="alert alert-success mt-3">
        @Model.MigrationResult
    </div>
}
else
{
    <p class="mt-3">Click the button below to start the migration.</p>
    <form method="get">
        <button type="submit" class="btn btn-primary">Start Migration</button>
    </form>
}