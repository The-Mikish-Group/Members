@page
@model Members.Areas.Admin.Pages.Accounting.RecordPaymentModel
@{
    ViewData["Title"] = "Record New Payment";
    // Adjust layout as needed, similar to AddInvoice.cshtml
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    @* Changed color for variety *@
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.SelectedUserID" class="form-label"></label>
                            <select asp-for="Input.SelectedUserID" asp-items="Model.UserSelectList" class="form-select">
                                <option value="">-- Select User --</option>
                            </select>
                            <span asp-validation-for="Input.SelectedUserID" class="text-danger"></span>
                        </div>

                        @* TODO: Future enhancement - Dynamically load unpaid invoices for the selected user here *@
                        @* For now, SelectedInvoiceID is a simple textbox if someone wants to type it.
                           Or, it can be hidden if we decide not to link payments to invoices directly in this version.
                           Let's make it a number input for now, but it's not very user-friendly without a lookup.
                        *@
                        <div class="mb-3">
                            <label asp-for="Input.SelectedInvoiceID" class="form-label"></label>
                            <input asp-for="Input.SelectedInvoiceID" class="form-control" type="number" />
                            <span asp-validation-for="Input.SelectedInvoiceID" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-6">
                                <label asp-for="Input.PaymentDate" class="form-label"></label>
                                <input asp-for="Input.PaymentDate" class="form-control" />
                                <span asp-validation-for="Input.PaymentDate" class="text-danger"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Input.Amount" class="form-label"></label>
                                <input asp-for="Input.Amount" class="form-control" />
                                <span asp-validation-for="Input.Amount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Method" class="form-label"></label>
                            <select asp-for="Input.Method" asp-items="Html.GetEnumSelectList<Members.Models.PaymentMethod>()" class="form-select">
                            </select>
                            <span asp-validation-for="Input.Method" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.ReferenceNumber" class="form-label"></label>
                            <input asp-for="Input.ReferenceNumber" class="form-control" />
                            <span asp-validation-for="Input.ReferenceNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Notes" class="form-label"></label>
                            <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Input.Notes" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success">Record Payment</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @* TODO: Add JavaScript here if we implement dynamic loading of unpaid invoices based on selected user *@
}