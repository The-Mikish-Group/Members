@page "{userId?}"
@model Members.Areas.Admin.Pages.Accounting.RecordPaymentModel
@{
    ViewData["Title"] = "Record New Payment";
    Layout = "/Views/Shared/_Layout.cshtml"; // Ensure this path is correct
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7"> @* Slightly wider for more invoice details *@
            <div class="card shadow">
                <div class="card-header bg-gold-light text-white">
                    <h4 class="text-gold-darker mb-0">
                        @ViewData["Title"]                       
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @Html.Raw(TempData["StatusMessage"]?.ToString()?.Replace("\n", "<br />"))
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        @if (Model.IsUserPreselected)
                        {
                            <input type="hidden" asp-for="Input.SelectedUserID" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">User</label>
                                <p class="form-control shadow">@Model.TargetUserName</p>
                            </div>

                            @* Display Open Invoices for Selection *@
                            <div class="mb-3">
                                <label asp-for="Input.SelectedInvoiceID" class="form-label"></label>
                                @if (Model.OpenInvoicesForUser != null && Model.OpenInvoicesForUser.Any())
                                {
                                    <div class="list-group" style="max-height: 200px; overflow-y: auto; border: 1px solid #ced4da; border-radius: 0.25rem;">
                                        @foreach (var invoice in Model.OpenInvoicesForUser)
                                        {
                                            <label class="list-group-item list-group-item-action">
                                                <input type="radio" asp-for="Input.SelectedInvoiceID" value="@invoice.InvoiceID" class="form-check-input me-1" />
                                                INV-@invoice.InvoiceID.ToString("D5") (@invoice.InvoiceDate.ToString("yyyy-MM-dd"))
                                                - @invoice.Description
                                                (Due: @invoice.AmountDue.ToString("C"), Paid: @invoice.AmountPaid.ToString("C"), Rem: @invoice.AmountRemaining.ToString("C"))
                                            </label>
                                        }
                                    </div>
                                    <span asp-validation-for="Input.SelectedInvoiceID" class="text-danger"></span>
                                }
                                else
                                {
                                    <p class="form-text">No open invoices found for this user to apply payment towards.</p>
                                    @* Hide other payment fields if no invoice to select, or allow general payment?
                                       For now, SelectedInvoiceID is required, so form won't submit without one.
                                       If OpenInvoicesForUser is empty, the radio button list won't render,
                                       and the RequiredValidator for SelectedInvoiceID will trigger on submit.
                                    *@
                                }
                            </div>
                        }
                        else // User not preselected, show dropdown (fallback)
                        {
                            <div class="mb-3">
                                <label asp-for="Input.SelectedUserID" class="form-label"></label>
                                <select asp-for="Input.SelectedUserID" asp-items="Model.UserSelectList" class="shadow form-select">
                                    <option value="">-- Select User --</option>
                                </select>
                                <span asp-validation-for="Input.SelectedUserID" class="text-danger"></span>
                            </div>
                            <p class="form-text text-muted">Select a user to see their open invoices.</p>
                        }

                        @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                        {
                            <input type="hidden" asp-for="ReturnUrl" />
                        }
                                                @* Only show these fields if a user context is established (either preselected or selected from dropdown)
                           AND if there are invoices to pay (or if you decide to allow payments without direct invoice linking later) *@
                        @if (!string.IsNullOrEmpty(Model.Input.SelectedUserID)) // Could also check Model.IsUserPreselected or if Model.OpenInvoicesForUser.Any()
                        {
                            <div class="row mb-3">
                                <div class="col-sm-6">
                                    <label asp-for="Input.PaymentDate" class="shadow form-label"></label>
                                    <input asp-for="Input.PaymentDate" class="shadow form-control" />
                                    <span asp-validation-for="Input.PaymentDate" class="text-danger"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="Input.Amount" class="form-label"></label>
                                    <input asp-for="Input.Amount" class="shadow form-control" />
                                    <span asp-validation-for="Input.Amount" class="text-danger"></span>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label asp-for="Input.Method" class="form-label"></label>
                                <select asp-for="Input.Method" asp-items="Html.GetEnumSelectList<Members.Models.PaymentMethod>()" class="shadow form-select">
                                </select>
                                <span asp-validation-for="Input.Method" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.ReferenceNumber" class="form-label"></label>
                                <input asp-for="Input.ReferenceNumber" class="shadow form-control" />
                                <span asp-validation-for="Input.ReferenceNumber" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Input.Notes" class="form-label"></label>
                                <textarea asp-for="Input.Notes" class="shadow form-control" rows="3"></textarea>
                                <span asp-validation-for="Input.Notes" class="text-danger"></span>
                            </div>
                            <div class="d-grid gap-2 mt-4">

                                <div class="row justify-content-center">
                                
                                    <div class="col-6 text-center">
                                        @if (Model.IsUserPreselected && !string.IsNullOrEmpty(Model.ReturnUrl))
                                        {
                                            <a href="@Model.ReturnUrl" class="shadow btn btn-sm btn-back mt-0"><i class="bi bi-arrow-left"> </i> Billing History</a>
                                        }
                                        else
                                        {
                                            <a href="~/Info/" class="shadow btn btn-sm btn-back mt-0"> <i class="bi bi-arrow-left"></i> Cancel</a>
                                        }
                                    </div>

                                    <div class="col-6 text-center">
                                        <button type="submit" class="shadow btn btn-sm btn-primary">Record Payment</button>
                                    </div>
                                </div>
                            </div>
                            
                        } @* End of conditional block for payment fields *@
                    </form>
                </div> @* card-body *@
            </div> @* card *@
        </div> @* col *@
    </div> @* row *@
</div> @* container *@

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}