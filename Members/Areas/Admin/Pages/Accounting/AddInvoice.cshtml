@page "{userId?}"
@model Members.Areas.Admin.Pages.Accounting.AddInvoiceModel
@{
    ViewData["Title"] = "Add New Invoice";
    Layout = "/Views/Shared/_Layout.cshtml"; // Ensure this path is correct for your project
}

<div class="container mt-4 mb-2">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        @ViewData["Title"]
                        @* @if (Model.IsUserPreselected && !string.IsNullOrEmpty(Model.TargetUserName))
                        {
                            <span> for @Model.TargetUserName</span>
                        } *@
                    </h4>
                </div>
                <div class="card-body">
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @Html.Raw(TempData["StatusMessage"]?.ToString()?.Replace("\n", "<br />"))
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        @if (Model.IsUserPreselected)
                        {
                            <input type="hidden" asp-for="Input.SelectedUserID" />
                            <div class="mb-3">
                                <label class="form-label fw-bold">Member</label>
                                <p class="form-control-plaintext">@Model.TargetUserName</p>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label asp-for="Input.SelectedUserID" class="form-label"></label>
                                <select asp-for="Input.SelectedUserID" asp-items="Model.UserSelectList" class="form-select">
                                    <option value="">-- Select User --</option>
                                </select>
                                <span asp-validation-for="Input.SelectedUserID" class="text-danger"></span>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(Model.ReturnUrl))
                        {
                            <input type="hidden" asp-for="ReturnUrl" />
                        }
                        <div class="row mb-3">
                            <div class="col-sm-6">
                                <label asp-for="Input.InvoiceDate" class="form-label"></label>
                                <input asp-for="Input.InvoiceDate" class="form-control" />
                                <span asp-validation-for="Input.InvoiceDate" class="text-danger"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Input.DueDate" class="form-label"></label>
                                <input asp-for="Input.DueDate" class="form-control" />
                                <span asp-validation-for="Input.DueDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label"></label>
                            <input asp-for="Input.Description" class="form-control" />
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-sm-6">
                                <label asp-for="Input.AmountDue" class="form-label"></label>
                                <input asp-for="Input.AmountDue" class="form-control" />
                                <span asp-validation-for="Input.AmountDue" class="text-danger"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Input.Type" class="form-label"></label>
                                <select asp-for="Input.Type" asp-items="Html.GetEnumSelectList<Members.Models.InvoiceType>()" class="form-select">
                                </select>
                                <span asp-validation-for="Input.Type" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">Create Invoice</button>
                            @if (Model.IsUserPreselected && !string.IsNullOrEmpty(Model.ReturnUrl))
                            {
                                <a href="@Model.ReturnUrl" class="btn btn-secondary mt-2">Back to Edit User</a>
                            }
                            else if (!Model.IsUserPreselected && !string.IsNullOrEmpty(Model.ReturnUrl))
                            {
                                // If accessed directly but still has a returnUrl (e.g. back to a list of invoices if we implement that)
                                <a href="@Model.ReturnUrl" class="btn btn-secondary mt-2">Cancel</a>
                            }
                        </div>
                    </form>
                </div> @* card-body *@
            </div> @* card *@
        </div> @* col *@
    </div> @* row *@
</div> @* container *@

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}





























































