@{
    ViewData["Title"] = "Welcome to Oaks-Village";

    ViewData["Description"] = "Discover the beautiful community of Oaks-Village.";
    ViewData["Canonical"] = "https://Oaks-Village.com/Info/index";
    ViewData["OGTitle"] = "Welcome to Oaks-Village";
    ViewData["OGDescription"] = "Explore our community and learn more about us.";
    ViewData["OGURL"] = "https://Oaks-Village.com/Info/Index";
    // ViewData["OGImage"] = "https://Oaks-Village.com/Images/LinkImages/SpecificPageImage.png"; //Optional
}

<!-- View -->
<head>
    <title>@ViewData["Title"]</title>
</head>

<div class="container row m-0 pb-2 pb-lg-4 gx-0 gy-2 gy-lg-3 mx-auto text-center">
    <div class="col-12 mt-0">
        <img alt="" class="img-fluid" src="~/images/svg/logos/logoOaksVillage.svg" />
    </div>
</div>

<div class="container row m-0 pb-0 pb-lg-2 gx-0 gy-2 gy-lg-3 mx-auto text-center">

    <div class="col-11 col-md-8 pt-sm-0 pt-lg-4 text-start mx-auto" >
        <p class="pb-2 text-gold-darker about-text-fs text-left">
           Welcome to the online home of Oaks Village, a friendly, non-smoking 55+ community in Avon Park, Florida. 
           <br><br>
           With over 70 residences and available building lots, Oaks Village offers a welcoming environment. 
           Southern Homes, our builder, has an office conveniently located inside the gate at Palmetto and Emmanuel Way.           
        </p>
    </div>

    <div class="col-12 pt-sm-0 pt-lg-4 px-2 mx-auto" >
        <img alt="" class="img-fluid rounded px-0 w-100" src="/Images/PageImages/uentry.jpg">
        <p class="py-1 text-gold-darker welcome-text-fs text-center">
            We invite you to visit!
        </p>
    </div>

</div>


