@using Microsoft.AspNetCore.Identity
@using System.IO;
@using Microsoft.AspNetCore.Mvc;
@using Microsoft.AspNetCore.Mvc.ViewComponents;
@using Microsoft.EntityFrameworkCore;
@using System.Linq;
@using System.Threading.Tasks;
@using System.Collections.Generic;
@using Members.Data;
@using Members.Models;

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject Members.Data.ApplicationDbContext DbContext

@{
    // This Site
    string siteURL = "https://oaks-village.com";

    // Set Site Name and Description (Change as needed)
    string description = ViewData["Description"]?.ToString() ?? "Welcome to Oaks-Village.";

    // Short name appears in Nav Bar at top on Phones... can be longer like siteName.
    string siteNameShort = "Oaks-Village";

    // Overall Structure and Organization
    string siteOrganization = "The Mikish Group";

    // Set default values
    string pageTitle = ViewData["Title"]?.ToString() ?? "Default Title";

    // Page Share Settings - (shows on "PageShare" card when a link is shared)
    string ogSite_Name = siteOrganization;
    string ogTitle = ViewData["OGTitle"]?.ToString() ?? pageTitle;
    string ogDescription = ViewData["OGDescription"]?.ToString() ?? description;
    string ogURL = ViewData["OGURL"]?.ToString() ?? siteURL;
    string canonical = ViewData["Canonical"]?.ToString() ?? "https://oaks-village.com/Info/Index";

    // Default Link Share Image (Change as needed)
    string ogImage = ViewData["OGImage"]?.ToString() ?? siteURL + "/Images/LinkImages/Oaks-Trees.png";
    string ogImageWidth = "1000";
    string ogImageHeight = "1000";
}

<!DOCTYPE html>
<html lang="en">
<head>

    <title>@pageTitle</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta name="mobile-web-app-capable" content="no">
    <meta name="description" content="@description" />
    <link rel="canonical" href="@canonical" />

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="apple-touch-icon" sizes="180x180" href="lib/icons/apple-touch-icon.png">

    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="192x192" href="favicon-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="favicon-512x512.png">
    <link rel="manifest" href="/lib/icons/site.webmanifest">

    <meta property="fb:app_id" content="966242223397117" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content="@ogTitle" />
    <meta property="og:determiner" content="The" />
    <meta property="og:description" content="@ogDescription" />
    <meta property="og:site_name" content="@ogSite_Name" />
    <meta property="og:url" content="@ogURL" />
    <meta property="og:image:url" content="@ogImage" />
    <meta property="og:image:alt" content="Logo Image" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content=@ogImageWidth />
    <meta property="og:image:height" content=@ogImageHeight />

    <meta name="twitter:card" content="photo" />
    <meta name="twitter:title" content="@ogTitle" />
    <meta name="twitter:image" content="@ogImage" />
    <meta name="twitter:image:width" content=@ogImageWidth />
    <meta name="twitter:image:height" content=@ogImageHeight />

    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <script type="text/javascript" src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf_viewer.min.css" integrity="sha512-tze+o/xG0w3yxxE8xe32piisVvI/LfcEuf6LW7lFLUxhio2SfFQ9mQ0TqB0avvonmxUXT7/l8+fnWkR03u85fQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js" integrity="sha512-q+4liFwdPC/bNdhUpZx6aXDx/h77yEQtn4I1slHydcbZK34nLaR3cAeYSJshoxIOq3mjEf7xJE8YWIUHMn+oCQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/lib/css/site.css" asp-append-version=" true" />
    <link rel="stylesheet" href="~/lib/css/sizes.css" asp-append-version=" true" />
    <link rel="stylesheet" href="~/lib/css/colors.css" asp-append-version=" true" />
    <link rel="stylesheet" href="~/lib/css/fontsize.css" asp-append-version=" true" />
    <link rel="stylesheet" href="~/lib/css/mycards.css" asp-append-version=" true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>

        <!-- Navbar --> 
        <nav class="navbar navbar-expand-lg navbar-light bg-gold-light px-0 position-relative">
            <div class="d-flex flex-grow-1 ps-2">

                <!-- Set to show on lg -->
                <a style="text-decoration: none" href="/"><img src="~/Images/Svg/Logos/SmallLogo.svg" class="navbar-overhang logo" alt="logo" /></a>
                <a style="text-decoration: none" class="nav-text nav-text-fs text-green-darker d-none d-lg-inline-block siteNameBig" href="/"><img src="~/Images/Svg/Logos/NameLogo.svg" class="nbLogo ps-2" alt="Oaks Village Logo" /></a>

                <!-- Set to show on sm -->
                <a style="text-decoration: none" class="nav-text text-decoration-none navbar-brand navbar-text nav-text-fs text-green-darker d-lg-none d-inline-block w-100 text-center me-0 ps-5 siteNameSmall" href="/"><img alt="" class="navbar-overhang logo px-2 pb-2" /><img src="~/Images/Svg/Logos/NameLogo.svg" class="nbLogo ms-4" alt="Oaks Village logo" /></a>

                <!-- Navbar Toggle Button -->
                <div class="text-left pe-2 pt-1">
                    <button class="navbar-toggler pe-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarToggler" aria-controls="navbarToggler" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

            </div>
            
            <!-- Navbar Links -->
            <div class="collapse navbar-collapse flex-grow-1 text-left px-2 pt-1" id="navbarToggler">
                <ul class="ps-4 bg-gold-light navbar-nav ms-auto flex-nowrap">

                    <!-- Welcome Dropdown -->
                    <li class="nav-item dropdown pt-5 pt-lg-0">

                        <!-- Welcome Dropdown Toggle -->
                        <a class="nav-link dropdown-toggle text-dark" href="#" id="welcomeDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-house-fill"></i> Welcome
                        </a>

                        <!-- Welcome Dropdown Menu -->
                        <ul class="dropdown-menu ps-4 ps-lg-2 bg-gold-light border-0" aria-labelledby="welcomeDropdown">
                            <li><a class="nav-link text-dark" asp-area="" asp-controller="Info" asp-action="Index"><i class="bi bi-house-fill"></i> Welcome</a></li>
                            <li><a class="nav-link text-dark" asp-area="" asp-controller="Info" asp-action="About"><i class="bi bi-info-circle-fill"></i> About</a></li>
                            <li><a class="nav-link text-dark" asp-area="" asp-controller="Info" asp-action="Facilities"><i class="bi bi-building-fill"></i> Facilities</a></li>
                            <li><a class="nav-link text-dark" href="~/Oaks"><i class="bi bi-images"></i> Galleries</a></li>
                        </ul>
                    </li>

                    <!-- Contact -->
                    <li class="nav-item">
                        <a class="nav-link text-dark" asp-area="" asp-controller="Info" asp-action="Contact">
                            <i class="bi bi-envelope-fill"></i> Contact
                        </a>
                    </li>

                    <!-- Members Dropdown -->
                    <li class="nav-item dropdown pt-0">

                        <!-- Members Dropdown Toggle -->
                        <a class="nav-link dropdown-toggle text-dark" href="#" id="membersDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-people-fill"></i> Members
                        </a>

                        <!-- Members Dropdown Menu -->
                        <ul class="dropdown-menu ps-4 ps-lg-2 bg-gold-light border-0" aria-labelledby="membersDropdown" style="min-width: 210px;">

                            <!-- Blog -->
                            <li>
                                <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Notices" target="_blank"><i class="bi bi-newspaper"></i> News and Notices</a>
                            </li>

                            <!-- PDF Documents Dropdown -->
                            <li class="nav-item dropdown">

                                <!-- PDF Documents Dropdown Toggle -->                                
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="pdfDocumentsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-file-earmark-pdf-fill me-2 text-gold-darker"></i> PDF Documents
                                </a>

                                <!-- PDF Documents Dropdown Menu -->
                                <ul class="dropdown-menu ms-4 ps-4 ps-lg-2 bg-gold-light border-0" aria-labelledby="pdfDocumentsDropdown">                                    
                                    @{
                                        // Fetch the non-empty categories directly in the layout
                                        var dynamicCategories = DbContext.PDFCategories
                                        .Where(c => c.CategoryFiles.Any()) // Only include categories with files
                                        .OrderBy(c => c.SortOrder)        // Order categories
                                        .ThenBy(c => c.CategoryName)
                                        .ToList(); // Execute the query

                                        // Check if any categories were found
                                        if (dynamicCategories != null && dynamicCategories.Any())
                                        {
                                            // Loop through the categories and create a link for each
                                            foreach (var category in dynamicCategories)
                                            {
                                                <li>                                                    
                                                    <a class="nav-link text-dark" asp-controller="Members" asp-action="ListFiles" asp-route-categoryId="@category.CategoryID">
                                                        <i class="bi bi-list-ul ms-2 text-gold-darker"></i> @category.CategoryName
                                                    </a>
                                                </li>
                                            }
                                        }
                                        else
                                        {
                                            // Optional: Display a placeholder if no categories are found
                                            <li><span class="dropdown-item-text">No PDF categories available</span></li>
                                        }
                                    }
                                </ul> 
                            </li>
                        </ul> 
                    </li> 

                    @if (SignInManager.IsSignedIn(User))
                    {
                        <!-- Admin Dropdown --> 
                        @if (SignInManager.IsSignedIn(User) && (User.IsInRole("Admin") || User.IsInRole("Manager")))
                        {
                            <li class="nav-item dropdown pt-0 pt-lg-0">

                                <!-- Admin Dropdown Toggle -->
                                <a class="nav-link dropdown-toggle text-dark" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill"></i> Admin
                                </a>

                                <!-- Admin Dropdown Menu -->
                                <ul class="dropdown-menu ps-4 ps-lg-2 bg-gold-light border-0" style="min-width: 200px;" aria-labelledby="adminDropdown">

                                    <!-- Admin Edit Members Dropdown -->
                                    <li class="nav-item dropdown">

                                        <!-- Admin Edit Members Dropdown Toggle -->
                                        <a class="nav-link dropdown-toggle text-dark" href="#" id="adminEditMembersDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-people-fill"></i> Edit Members
                                        </a>

                                        <!-- Admin Edit Members Dropdown Menu -->
                                        <ul class="dropdown-menu ms-4 ps-4 ps-lg-2 bg-gold-light border-0" style="min-width: 200px;" aria-labelledby="adminEditMembersDropdown" data-bs-auto-close="outside">
                                            <li><a class="nav-link text-dark" asp-area="Identity" asp-page="/AddUser" title="Add Member"><i class="bi bi-plus-circle"></i> Add Member</a></li>
                                            <li><a class="nav-link text-dark" asp-area="Identity" asp-page="/Users" title="Edit Members"><i class="bi bi-person-gear"></i> Edit Members</a></li>
                                            <li><a class="nav-link text-dark" asp-area="Identity" asp-page="/UsersGrid" title="Members Grid"><i class="bi bi-grid-fill"></i> Members Grid</a></li>
                                            <li><a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/ResendEmailConfirmation"><i class="bi bi-envelope-check"></i> Send 'Confirm Email'</a></li>
                                        </ul>

                                    </li>

                                    <!-- Admin PDF Folders Dropdown -->
                                    <li class="nav-item dropdown">

                                        <!-- Admin PDF Folders Dropdown Toggle -->
                                        <a class="nav-link dropdown-toggle text-dark" href="#" id="adminPdfFoldersDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-folder-fill text-gold-dark"></i> Edit PDF Menus
                                        </a>

                                        <!-- Admin PDF Folders Dropdown Menu -->
                                        <ul class="dropdown-menu ms-4 ps-4 ps-lg-2 bg-gold-light border-0" style="min-width: 200px;" aria-labelledby="adminPdfFoldersDropdown" data-bs-auto-close="outside">
                                            <li><a class="nav-link text-dark" asp-area="" asp-controller="PdfCategory" asp-action="ManageCategories" title="Manage PDF Categories"><i class="bi bi-file-earmark-pdf-fill me-0 text-gold-darker"></i> Manage Categories</a></li>
                                            <li><a class="nav-link text-dark" asp-area="" asp-controller="PdfCategory" asp-action="ManageCategoryFiles" title="Manage PDF Category Files"><i class="bi bi-list-ul me-0 text-gold-darker"></i> Manage Documents</a></li>
                                            <li><a class="nav-link text-dark" asp-area="" asp-controller="PdfGeneration" asp-action="CreatePdf" title="New Directory PDF"><i class="bi bi-file-earmark-plus me-0 text-gold-darker"></i> New Directory PDF</a></li>
                                            <li><a class="nav-link text-dark" asp-area="Identity" asp-page="/Admin/AdminFiles" title="Delete Protected Files"><i class="bi bi-list-ul me-0 text-gold-darker"></i> Delete Protected Files</a></li>
                                        </ul>

                                    </li>
                                   
                                </ul>
                            </li>
                        }

                        <!-- Profile -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Manage/Index" title="Profile">
                                <i class="bi bi-gear-fill"></i> Profile
                            </a>
                        </li>

                        <!-- Logout -->
                        <li class="nav-item">
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Info", new { area = "" })">
                                <button type="submit" class="nav-link btn btn-sm btn-link text-dark">
                                    <i class="bi bi-unlock-fill"></i> Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <!-- Register -->
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">
                                <i class="bi bi-person-plus-fill"></i> Register
                            </a>
                        </li>

                        <!-- Login -->
                        <li class="nav-item">
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Index", "Info", new { area = "" })">
                                <button type="submit" class="nav-link btn btn-sm btn-link text-dark">
                                    <i class="bi bi-lock-fill"></i> Login
                                </button>
                            </form>
                        </li>
                    }
                
                </ul>
            </div>
        </nav>
    </header>

    <div id="MainContainer" class="m-0 p-0">
        <main role="main" class="m-0 p-0">
            @RenderBody()
        </main>
    </div>

    <div id="footer" class="navbar navbar-dark border-top bg-gold-footer" role="contentinfo" aria-label="Site footer">

        <div class="container text-right">
            <div class="row w-100 gx-0 gx-lg-5">

                <div class="col-4">                    
                    <ul class="navbar-nav ms-auto flex-nowrap ps-2">
                        <li class="nav-item text-light"><a class="nav-link footer-fs text-nowrap " href="~/Info/">Welcome</a></li>
                        <li class="nav-item text-light"><a class="nav-link footer-fs text-nowrap " href="~/Info/About">About Us</a></li>
                        <li class="nav-item text-light"><a class="nav-link footer-fs text-nowrap" href="~/Info/Facilities">Facilities</a></li>
                        <li class="nav-item text-light"><a class="nav-link footer-fs" href="~/Oaks">Galleries</a></li>
                    </ul>
                </div>

                <div class="col-4 pe-0">                    
                    <ul class="navbar-nav ms-auto flex-nowrap ps-2">

                        <!-- Contact in the footer -->
                        <li class="nav-item text-light">
                            <a class="nav-link footer-fs" href="~/Info/Contact">Contact</a>
                        </li>

                        <!-- More Links in the footer -->
                        <li class="nav-item text-light">
                            <a class="nav-link footer-fs" href="~/Info/MoreLinks">More Links</a>
                        </li>

                        <!-- Members Dropdown in the footer -->
                        <li class="nav-item dropdown pt-0 pt-lg-0">                         

                            <!-- Members Dropdown Toggle in the footer -->
                            <a class="nav-link dropdown-toggle text-gold-dark footer-fs" href="#" id="membersfooterDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-people-fill"></i> Members
                            </a>

                            <!-- Members Dropdown Menu in the footer -->
                            <ul class="dropdown-menu ps-4 ps-lg-2 bg-transparent border-0" aria-labelledby="membersfooterDropdown" style="min-width: 210px;">

                                <!-- News and Notices -->
                                <li class="nav-item text-light">
                                    <a class="nav-link footer-fs text-nowrap" asp-area="" asp-controller="Home" asp-action="Notices" target="_blank">
                                        <i class="bi bi-newspaper"></i> News and Notices
                                    </a>
                                </li>

                                <!-- Start of Nested "PDF Documents" Dropdown (wrapping the loop) -->
                                <li class="nav-item dropdown">

                                    <!-- PDF Documents Dropdown Toggle in the footer -->
                                    <a class="nav-link dropdown-toggle text-gold-dark footer-fs" href="#" id="pdfDocumentsFooterDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">                                       
                                        <i class="bi bi-file-earmark-pdf-fill me-0 text-gold-dark"></i> PDF Documents
                                    </a>
                                    <!-- PDF Documents Menu in the footer -->
                                    <ul class="dropdown-menu ps-4 ps-lg-2 bg-transparent border-0" aria-labelledby="pdfDocumentsFooterDropdown">                                        
                                        @{
                                            // Fetch the non-empty categories directly in the layout
                                            dynamicCategories = DbContext.PDFCategories
                                            .Where(c => c.CategoryFiles.Any()) // Only include categories with files
                                            .OrderBy(c => c.SortOrder)        // Order categories
                                            .ThenBy(c => c.CategoryName)
                                            .ToList(); // Execute the query

                                            // Check if any categories were found
                                            if (dynamicCategories != null && dynamicCategories.Any())
                                            {
                                                // Loop through the categories and create a link for each
                                                foreach (var category in dynamicCategories)
                                                {
                                                    // Maintain footer styles for nested list items
                                                    <li class="nav-item text-light">
                                                        <a class="nav-link footer-fs text-nowrap" asp-controller="Members" asp-action="ListFiles" asp-route-categoryId="@category.CategoryID">
                                                            <i class="bi bi-list-ul ms-2 text-gold-darker"></i> @category.CategoryName
                                                        </a>
                                                    </li>
                                                }
                                            }
                                            else
                                            {
                                                // Optional: Display a placeholder if no categories are found
                                                <li><span class="dropdown-item-text text-light">No PDF categories available</span></li> <!-- Add text-light -->
                                            }
                                        }
                                    </ul> 
                                </li> 
                            </ul> 
                        </li>
                    </ul>
                </div>

                <!-- TOS and Privacy Links in the footer -->
                <div class="col-4 pe-0">                   
                    <ul class="navbar-nav ms-auto flex-nowrap ps-2">

                        <!-- TOS -->
                        <li class="nav-item text-light">
                            <a class="nav-link footer-fs text-nowrap" href="~/Info/TOS">TOS</a>
                        </li>

                        <!-- Privacy -->
                        <li class="nav-item text-light">
                            <a class="nav-link footer-fs" href="~/Info/Privacy">Privacy</a>
                        </li>

                    </ul>
                </div>
            </div>
        </div>

        <!-- Footer logo and text -->
        <div class="w-100 bg-gray text-white pt-4">
            <p class="text-center py-2 text-white" style="font-size: 10px;"><img class="footer-logo" src="~/Images/Svg/Logos/SmallLogo.svg" />  @siteNameShort Copyright © @DateTime.Now.Year</p>
        </div>

    </div>    
    
    <script>

        // Adjust the position of the footer based on actual content and footer height
        function adjustFooterPosition() {
            var mainContainer = document.getElementById('MainContainer');
            var footer = document.getElementById('footer');

            // Calculate the space between content, footer, and the bottom of the page
            var spaceToBottom = window.innerHeight - mainContainer.offsetHeight - footer.offsetHeight;

            // Adjust the position of the footer if the space is less than 0
            footer.style.bottom = (spaceToBottom < 0) ? -spaceToBottom + 'px' : 'auto';
        }

        // Call the function when the page loads and when it resizes
        window.addEventListener('load', adjustFooterPosition);
        window.addEventListener('resize', adjustFooterPosition);

        // Add event listeners with stopPropagation for nested dropdown toggles
        // This prevents clicks on sub-toggles from closing their parent dropdowns
        document.addEventListener('DOMContentLoaded', function() {
            const adminEditMembersToggle = document.querySelector('#adminEditMembersDropdown');
            if (adminEditMembersToggle) {
                adminEditMembersToggle.addEventListener('click', function(event) {
                    event.stopPropagation();
                });
            }
            const adminGalleryToggle = document.querySelector('#adminGalleryDropdown');
            if (adminGalleryToggle) {
                adminGalleryToggle.addEventListener('click', function(event) {
                    event.stopPropagation();
                });
            }

            const adminPdfFoldersToggle = document.querySelector('#adminPdfFoldersDropdown');
            if (adminPdfFoldersToggle) {
                adminPdfFoldersToggle.addEventListener('click', function(event) {
                    event.stopPropagation();
                });
            }

            // Add stopPropagation for the nested PDF Documents dropdown toggle in the header
            const pdfDocumentsToggle = document.querySelector('#pdfDocumentsDropdown');
            if (pdfDocumentsToggle) {
                pdfDocumentsToggle.addEventListener('click', function(event) {
                    event.stopPropagation();
                });
            }

            // Add stopPropagation for the nested PDF Documents dropdown toggle in the footer
             const pdfDocumentsFooterToggle = document.querySelector('#pdfDocumentsFooterDropdown');
             if (pdfDocumentsFooterToggle) {
                 pdfDocumentsFooterToggle.addEventListener('click', function(event) {
                     event.stopPropagation();
                 });
             }
        });

    </script>

    <!-- This renders the Scripts section from individual views -->
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>