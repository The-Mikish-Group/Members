<!-- File: Views/Shared/Components/CategoryMenu/Default.cshtml -->

@model IEnumerable<Members.Models.PDFCategory>

@*
    This view component view renders the list items (<li>) for
    the dynamic category menu in the navigation bar dropdown.
*@

@if (Model != null && Model.Any())
{
    @foreach (var category in Model)
    {
        <li>
            {{-- Create a link for each category --}}
            {{-- The link goes to the ListFiles action in the Members controller --}}
            {{-- It passes the category.CategoryID as a route parameter --}}
            <a class="dropdown-item text-dark" asp-controller="Members" asp-action="ListFiles" asp-route-categoryId="@category.CategoryID">
                <i class="bi bi-folder me-2"></i> @category.CategoryName
            </a>
        </li>
    }
}
