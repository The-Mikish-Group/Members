@model IEnumerable<Members.Models.ImageViewModel>
@using Members.Models

@{
    ViewData["Title"] = $"Manage Images for: {ViewBag.GalleryName}";
}

<h1 class="text-center my-2">Manage Images for: @ViewBag.GalleryName</h1>

<div class="text-center mb-3">
    <a asp-controller="Image" asp-action="ManageGalleries" class="btn btn-sm btn-secondary"><i class="bi bi-box-arrow-left"></i> Back to Manage Galleries</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    @* <div class="alert alert-success">@TempData["SuccessMessage"]</div> *@
}
@if (TempData["ErrorMessage"] != null)
{
    @* <div class="alert alert-danger">@TempData["ErrorMessage"]</div> *@
}

<div class="row gx-1 gy-0 m-2">
    <div class="col-md-8 mx-auto">
        
        <!-- Shaddowed Card -->
        <div class="card shadow rounded p-2 bg-Card-Menu h-100">
            
            <!-- Upload New Files -->
            <h2 class="mt-4 mb-2 ps-2">Upload a New Image</h2>    
            
            <!-- Upload Image Form -->
            <form asp-controller="Image" asp-action="UploadImage" method="post" enctype="multipart/form-data" class="mb-4">

                <!-- Hidden Gallery Name field -->
                <input type="hidden" name="GalleryName" value="@ViewBag.GalleryName" />

                <!-- Button Group -->
                <div class="input-group">

                    <!-- Upload File name -->
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" required>

                    <!-- Save -->
                    <button type="submit" class="btn btn-sm btn-primary">
                        <i class="bi bi-save"></i>
                    </button>

                </div>

                <!-- Validation Message -->
                <span class="text-danger">@Html.ValidationMessage("ImageFile")</span>

            </form>

            <!-- Existing Images -->
            @if (Model != null && Model.Any())
                {
                    <!-- Heading -->
                    <h2 class="mt-4 mb-2 ps-2">Existing Images</h2>

                    <!-- Image Row -->
                    <div class="row gx-1 gy-0 m-1">
                        @foreach (var image in Model)
                        {
                            <!-- Image Column -->
                            <div class="col-md-6 col-lg-4 col-xl-4 mb-2">

                                <!-- Shaddowed Card -->
                                <div class="card shadow rounded p-2 bg-Card-Menu h-100">

                                    <!-- Image Thumbnail -->
                                    <img src="@image.ThumbnailUrl" class="card-img-top img-fluid" alt="@System.IO.Path.GetFileNameWithoutExtension(image.FileName)" style="width: 100%; height: 200px; object-fit: cover;">
                                
                                    <div class="card-body text-center">

                                        <!-- File Name (minus the extension) -->
                                        <p class="card-text">@System.IO.Path.GetFileNameWithoutExtension(image.FileName)</p>
                                    
                                        <!-- Button Group -->
                                        <div class="btn-group mt-2" role="group" aria-label="Image Actions">
                                        
                                            <!-- Rename Button -->
                                            <button type="button" class="rounded btn btn-sm btn-warning mx-2" data-bs-toggle="modal" data-bs-target="#renameImageModal_@image.FileName.Replace(".", "_")"><i class="bi bi-pencil"></i> Rename</button>
                                                                                
                                            <!-- Delete with Confirm Dialog -->
                                            <form asp-controller="Image" asp-action="DeleteImage" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete \'@image.FileName\'?');">
                                                <input type="hidden" name="galleryName" value="@image.GalleryName" />
                                                <input type="hidden" name="fileName" value="@image.FileName" />

                                                <!-- Delete Button -->
                                                <button type="submit" class="rounded btn btn-sm btn-danger mx-2"><i class="bi bi-x-circle"></i> Delete</button>

                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Modal Rename Image -->
                            <div class="modal fade" id="renameImageModal_@image.FileName.Replace(".", "_")" tabindex="-1" aria-labelledby="renameImageModalLabel_@image.FileName.Replace(".", "_")" aria-hidden="true">
                                <div class="modal-dialog">
                                    <div class="modal-content">
                                        <form asp-controller="Image" asp-action="RenameImage" method="post">
                                            <div class="modal-header">
                                                <h5 class="modal-title" id="renameImageModalLabel_@image.FileName.Replace(".", "_")">Rename Image: @image.FileName</h5>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                <input type="hidden" name="galleryName" value="@image.GalleryName" />
                                                <input type="hidden" name="oldFileName" value="@image.FileName" />
                                                <div class="mb-3">
                                                    <label for="newFileName_@image.FileName.Replace(".", "_")" class="form-label">New File Name:</label>
                                                    <input type="text" class="form-control" id="newFileName_@image.FileName.Replace(".", "_")" name="newFileName" value="@image.FileName" required>
                                                </div>
                                            </div>

                                            <!-- Buttons -->
                                            <div class="modal-footer">

                                                <!-- Close -->
                                                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                                                    <i class="bi bi-x-circle"></i> Close
                                                </button>

                                                <!-- Rename -->
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-pencil"></i> Rename
                                                </button>

                                            </div>

                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- No Images loaded yet!-->
                    <div class="text-center text-gold-dark">This gallery is empty. Upload images above!</div>
                }    
        
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}