@model Members.Models.ImageViewModel

@{
    ViewData["Title"] = Model.FileName;
}

<!-- Title: File Name (without extension) -->
<h1 class="text-center Text-gold-darker my-2">@System.IO.Path.GetFileNameWithoutExtension(Model.FileName)</h1>

<!-- Back Button -->
<div class="mb-3 text-center">
    <a asp-controller="Image" asp-action="GalleryView" asp-route-galleryName="@Model.GalleryName" class="btn btn-sm btn-back me-2"
       data-bs-toggle="tooltip" data-bs-placement="top" title="Back to Gallery">
        <i class="bi bi-box-arrow-left me-2"></i> Back to Gallery
    </a>
</div>

<!-- Full Image View (Fits Width) -->
<div class="text-center mb-2">
    <img src="@Model.FullImageUrl" class="img-fluid" alt="@Model.FileName" style="max-width: 100%; height: auto;">
</div>