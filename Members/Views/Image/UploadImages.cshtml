@*
  View for uploading images to a specific gallery folder.
  ViewData["GalleryName"]: string - The name of the target gallery folder.
*@
@{
    var galleryName = ViewData["GalleryName"] as string;
    ViewData["Title"] = $"Upload Images to: {galleryName}";
}

<!-- Page Title -->
<div class="row justify-content-center my-2 mx-auto p-2">
    <div class="col-md-8 bg-Transparent p-2">
        <h1> <i class="bi bi-cloud-upload"></i> @ViewData["Title"]</h1>
    </div>
</div>

<!-- Upload file form -->
<div class="row justify-content-center my-2 mx-auto p-2">
    <div class="shadow border rounded col-md-8 bg-Card-Menu p-2">
        @* Form to submit files to the UploadImages POST action *@
        @* IMPORTANT: enctype="multipart/form-data" is required for file uploads *@
        <form asp-action="UploadImages" method="post" enctype="multipart/form-data">
            @* Add Anti-Forgery Token *@
            @Html.AntiForgeryToken()

            @* Display validation errors *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Hidden input to pass the target gallery folder name *@
            <input type="hidden" name="folderName" value="@galleryName" />

            <div class="form-group">
                <label for="files" class="control-label fw-bold fs-3">
                    <i class="bi bi-image-fill"></i>
                    Select a new Picture to Upload:
                </label>
                @* File input field. 'multiple' attribute allows selecting multiple files *@
                @* Name attribute must match the parameter name (List<IFormFile> files) in the controller action *@
                <input type="file" id="files" name="files" class="form-control" multiple accept="image/*" /> @* accept="image/*" suggests image files *@
                @* Optional: Add validation message *@
                @* <span asp-validation-for="Files" class="text-danger"></span> *@
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Upload</button>
                @* Link back to the ManageGallery page for this folder *@
                <a asp-action="ManageGallery" asp-route-folderName="@galleryName" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@* Optional: Add client-side validation scripts or file preview scripts *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
