@*
  View for creating a new image gallery folder.
  Model: Not strictly needed for a simple form, but can use a ViewModel if adding validation summary etc.
*@
@{
    ViewData["Title"] = "Create a New Gallery";
}

<h1 class="text-center">@ViewData["Title"]</h1>

<hr />
<div class="row justify-content-center my-2 mx-auto p-2">
    <div class="shadow border rounded col-md-8 bg-Card-Menu p-2">
        @* Form to submit the new folder name to the CreateFolder POST action *@
        <form asp-action="CreateFolder" method="post">
            @* Add Anti-Forgery Token *@
            @Html.AntiForgeryToken()

            @* Display validation errors *@
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label for="folderName" class="control-label">Gallery Name:</label>
                @* Input field for the folder name. Name attribute must match the parameter name in the controller action *@
                <input id="folderName" name="folderName" class="form-control" />
                @* Optional: Add validation message for the input field *@
                @* <span asp-validation-for="FolderName" class="text-danger"></span> *@
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Create</button>
                @* Link back to the Index page *@
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@* Optional: Add client-side validation scripts *@
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
