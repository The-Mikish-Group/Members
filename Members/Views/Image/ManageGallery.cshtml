<!-- Status -->
<div class="row justify-content-center my-2 mx-auto">
    <div class="col-md-8 bg-transparent p-2">
        <!-- Display success or error messages from TempData -->
        <!-- Added dismissible alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>
</div>

<!-- Images Grid -->
@if (Model != null && Model.Images.Any()) 

{
    <div class="row justify-content-center my-2 mx-auto p-2">
        <div class="shadow border rounded col-md-8 bg-PDF-Menu p-2">
            <div class="row mt-2">

                <!-- Loop through Images -->
                <!-- Display each image with a delete and rename button -->
                @foreach (var image in Model.Images) 
                {
                    <div class="col-lg-4 mb-4 mx-auto">
                        <div class="card mx-auto bg-white">

                            <!-- Display the thumbnail image. Construct the URL using the gallery path and thumbnail file name from the image model -->
                            <img src="@(galleryPath + "/" + image.ThumbnailFileName)" class="card-img-top" alt="@image.DisplayName" style="object-fit: cover; height: 350px;">
                            <div class="card-body">
                                <!-- Display the original file name (remove _thumb.jpg) using the DisplayName property -->
                                <h6 class="card-title text-center">@image.DisplayName</h6> <!-- Center the title -->

                                <!-- Action Buttons Container -->
                                <div class="d-flex justify-content-around">
                                    <!-- Use flexbox to space out buttons -->

                                    <!-- Rename Button (triggers modal/form) -->
                                    <!-- Using a button that will likely trigger a modal or inline edit with JavaScript -->
                                    <!-- For simplicity in this HTML, we'll use a placeholder button.
                                       Real implementation would involve a modal form. -->
                                    <button type="button" class="btn btn-info btn-sm rename-button"
                                            data-gallery-name="@image.GalleryName"
                                            data-thumbnail-filename="@image.ThumbnailFileName"
                                            data-display-name="@image.DisplayName"
                                            data-bs-toggle="modal" data-bs-target="#renameModal">
                                        Rename
                                    </button>

                                    <!-- Delete Image Form - Use a form for POST request -->
                                    <form asp-action="DeleteImage" method="post" style="display:inline;">
                                        <!-- Pass the folder name and the THUMBNAIL file name for deletion -->
                                        <input type="hidden" name="folderName" value="@image.GalleryName" />
                                        <input type="hidden" name="fileName" value="@image.ThumbnailFileName" /> <!-- Pass the thumbnail name to identify the file(s) to delete -->
                                        <!-- Add Anti-Forgery Token -->
                                        @Html.AntiForgeryToken()
                                        <!-- Delete button - Add confirmation using JavaScript -->
                                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete the image \'@image.DisplayName\'?');">Delete</button> <!-- Use display name in confirmation -->
                                    </form>
                                </div> <!-- End Action Buttons Container -->

                            </div>

                        </div>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- --- Pagination Controls --- -->
    <nav aria-label="Gallery Pagination">
        <ul class="pagination justify-content-center">
            <!-- Previous Page Button -->
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" asp-action="ManageGallery"
                   asp-route-folderName="@Model.GalleryName"
                   asp-route-page="@(Model.PageNumber - 1)"
                   asp-route-pageSize="@Model.PageSize"
                   tabindex="@(Model.HasPreviousPage ? "" : "-1")"
                   aria-disabled="@(!Model.HasPreviousPage)">Previous</a>
            </li>

            <!-- Page Number Links (Simple Example: Show current, previous, and next few pages) -->
            @{
                int startPage = Math.Max(1, Model.PageNumber - 2);
                int endPage = Math.Min(Model.TotalPages, Model.PageNumber + 2);
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" asp-action="ManageGallery"
                       asp-route-folderName="@Model.GalleryName"
                       asp-route-page="@i"
                       asp-route-pageSize="@Model.PageSize">
                        @i <!-- Display the page number -->
                        <!-- CORRECTED: Use Html.Raw to render the span as HTML -->
                        @(i == Model.PageNumber ? Html.Raw("<span class=\"visually-hidden\">(current)</span>") : Html.Raw(""))
                    </a>
                </li>
            }

            <!-- Ellipsis if there are pages after the displayed range -->
            @if (endPage < Model.TotalPages)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>
                <!-- Link to the last page -->
                <li class="page-item">
                    <a class="page-link" asp-action="ManageGallery"
                       asp-route-folderName="@Model.GalleryName"
                       asp-route-page="@Model.TotalPages"
                       asp-route-pageSize="@Model.PageSize">@Model.TotalPages</a>
                </li>
            }


            <!-- Next Page Button -->
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" asp-action="ManageGallery"
                   asp-route-folderName="@Model.GalleryName"
                   asp-route-page="@(Model.PageNumber + 1)"
                   asp-route-pageSize="@Model.PageSize"
                   tabindex="@(Model.HasNextPage ? "" : "-1")"
                   aria-disabled="@(!Model.HasNextPage)">Next</a>
            </li>
        </ul>
    </nav>
    <!-- --- End Pagination Controls --- -->

}

<!-- --- Rename Modal Structure --- -->
<!-- This is a basic Bootstrap modal structure. You'll need Bootstrap JS/CSS for this to work. -->
<div class="modal fade" id="renameModal" tabindex="-1" aria-labelledby="renameModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="renameModalLabel">Rename Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <!-- Form to submit the rename request -->
            <form asp-action="RenameImage" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="renameGalleryName" name="folderName" value="@galleryName" />
                    <input type="hidden" id="renameThumbnailFileName" name="currentThumbnailFileName" value="" /> <!-- Will be populated by JS -->

                    <div class="form-group">
                        <label for="newImageName" class="control-label">New Image Name (without extension)</label>
                        <input type="text" id="newImageName" name="newBaseName" class="form-control" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Rename</button>
                </div>
            </form>
        </div>
    </div>
</div>
<!-- --- End Rename Modal Structure --- -->

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // JavaScript to handle the rename modal
        var renameModal = document.getElementById('renameModal');
        renameModal.addEventListener('show.bs.modal', function (event) {
            // Button that triggered the modal
            var button = event.relatedTarget;

            // Extract info from data-* attributes
            var galleryName = button.getAttribute('data-gallery-name');
            var thumbnailFileName = button.getAttribute('data-thumbnail-filename');
            var displayName = button.getAttribute('data-display-name'); // The current display name

            // Update the modal's content.
            var modalTitle = renameModal.querySelector('.modal-title');
            var renameGalleryNameInput = renameModal.querySelector('#renameGalleryName');
            var renameThumbnailFileNameInput = renameModal.querySelector('#renameThumbnailFileName');
            var newImageNameInput = renameModal.querySelector('#newImageName');

            modalTitle.textContent = 'Rename Image: ' + displayName;
            renameGalleryNameInput.value = galleryName;
            renameThumbnailFileNameInput.value = thumbnailFileName;
            newImageNameInput.value = displayName; // Pre-fill with the current display name
        });

         // JavaScript to display the selected file name(s)
        document.getElementById('files').addEventListener('change', function() {
            const fileNameDisplay = document.getElementById('fileNameDisplay');
            if (this.files && this.files.length > 0) {
                // Display the names of the selected files
                const fileNames = Array.from(this.files).map(file => file.name);
                fileNameDisplay.value = fileNames.join(', '); // Join multiple names with a comma and space
            } else {
                fileNameDisplay.value = '--No file(s) chosen--'; // Reset if no file is selected
            }
        });
    </script>
}
