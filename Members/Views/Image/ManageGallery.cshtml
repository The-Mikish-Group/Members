@*
  View for displaying images within a specific gallery folder with pagination.
  Model: PaginatedGalleryViewModel - Contains the list of images for the current page and pagination metadata.
*@
@model Members.Models.PaginatedGalleryViewModel
@using System.IO; <!-- Added this using directive to access Path methods -->

@{
    var galleryName = Model.GalleryName; // Get gallery name from the model
    ViewData["Title"] = $"Manage Gallery: {galleryName}";
    var galleryPath = $"/Gallery/Oaks/{galleryName}"; // Base URL path for images in this gallery
}

<!-- Page Title -->
<h1 class="text-center">@ViewData["Title"]</h1>

<!-- Back to Galleries Button -->
<div class="row justify-content-center my-2 mx-auto p-2">
    <div class="col-md-8 bg-transparent p-2">
        <p>
            <!-- Link back to the main gallery index -->
            <a asp-action="Index" class="btn btn-option"><i class="bi bi-arrow-left text-gold-darker"></i> Back to Galleries</a>
        </p>
    </div>
</div>

