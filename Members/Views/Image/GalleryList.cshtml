@model IEnumerable<Members.Models.GalleryViewModel>

@{
    ViewData["Title"] = "Image Galleries";
}

@if (TempData["SuccessMessage"] != null)
{
    //<div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    //<div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<!-- Title: Image Galleries -->
<h1 class="text-center text-gold-darker my-2"><i class="bi bi-image"></i> Image Galleries</h1>

<!-- Row and Column setup for Card -->
<div class="container row justify-content-center mx-auto p-1">
    <div class="col-lg-6 col-md-10 m-1 p-1">

        <!-- Shaddowed Card -->
        <div class="card shadow rounded border bg-Card-Menu">
            <div class="card-body p-0">
                
                <!-- Check to see if there are any Galleries -->
                @if (Model != null && Model.Any())
                {
                    <!-- List of Galleries -->
                    <ul class="list-group list-group-flush">

                        <!-- Loop through each gallery and create a list item for it -->                        
                        @foreach (var gallery in Model)
                        {
                            <!-- List item with link to the gallery view -->
                            <li class="list-group-item bg-transparent text-gold-darker" style="cursor: pointer;">
                                <a asp-controller="Image" asp-action="GalleryView" asp-route-galleryName="@gallery.Name" class="text-decoration-none text-gold-dark d-block"><i class="bi bi-images"></i> @gallery.Name (Images: @gallery.ImageCount)</a>
                            </li>                         
                        }
                    </ul>  
                }
                else
                {
                    <div class="text-center">
                        <p>No galleries available yet.</p>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

@if (User.IsInRole("Admin") || User.IsInRole("Manager"))
{
    <div class="mt-4 text-center">
        <a asp-controller="Image" asp-action="ManageGalleries" class="btn btn-sm btn-back text-gold-dark"><i class="bi bi-shield-lock"></i> Manage Galleries</a>
    </div>
}

@section Styles {
    <style>
        /* Styles to remove the borders from the list items */
        .list-group-item {
            border-bottom: none !important;
        }

            .list-group-item:first-child {
                border-top: none !important;
            }

            .list-group-item:last-child {
                border-bottom: none !important;
            }

            /* CSS to control the link color on hover/focus */
            /* Target the link directly within the list item on hover/focus */
            .list-group-item:hover a.text-gold-darker,
            .list-group-item:focus a.text-gold-darker,
            .list-group-item a.text-gold-darker:hover,
            .list-group-item a.text-gold-darker:focus {
                color: #3b3726 !important; /* Use the dark gold color */
            }

            /* Optional: Adjust the background color of the list item on hover/focus */
            .list-group-item:hover,
            .list-group-item:focus {
                background-color: rgba(0, 0, 0, 0.05) !important; /* Example subtle background */
            }

        a:hover,
        a:focus {
            color: forestgreen !important;
        }
    </style>
}
