<!-- Status -->
<div class="row justify-content-center my-2 mx-auto">
    <div class="col-md-8 bg-transparent p-2">
        <!-- Display success or error messages from TempData -->
        <!-- Added dismissible alerts -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["WarningMessage"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                @TempData["WarningMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
    </div>
</div>

<!-- Existing Galleries -->
<div class="row justify-content-center my-2 mx-auto p-2">
    <div class="shadow border rounded col-md-8 bg-Card-Menu p-2">

        <!-- Display the list of existing galleries -->
        @if (Model != null && Model.Any())
        {
            <h2 class="pb-2"><i class="bi bi-list-ul"></i> Existing Galleries</h2>
            <h6 class="pb-1">(Select one to Manage)</h6>
            <ul class="list-group">

                <!-- Loop through each gallery name in the model -->
                @foreach (var galleryName in Model)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <!-- Link to manage the specific gallery -->
                        <a class="nav-link" asp-action="ManageGallery" asp-route-folderName="@galleryName"><i class="bi bi-images"></i> @galleryName</a>

                        <!-- Buttons for managing the gallery (e.g., delete) -->
                        <div>
                            <!-- Delete Folder Form - Use a form for POST request -->
                            <form asp-action="DeleteFolder" method="post" style="display:inline;">
                                <!-- Pass the folder name as a hidden input -->
                                <input type="hidden" name="folderName" value="@galleryName" />
                                <!-- Add Anti-Forgery Token -->
                                @Html.AntiForgeryToken()
                                <!-- Delete button - Add confirmation using JavaScript -->
                                <button type="submit" class="btn btn-delete py-2 px-2" onclick="return confirm('Are you sure you want to delete \'@galleryName\' and ALL its contents?');"><i class="bi bi-trash-fill px-0"></i></button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No galleries found. Create a new one to get started.</p>
        }
    </div>
</div>
